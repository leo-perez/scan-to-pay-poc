# Database (required)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# BlinkPay (required for real payments; omit and set USE_MOCK_PAYMENT=true to test without BlinkPay)
# Get sandbox credentials: https://www.blinkpay.co.nz/resources-developers or https://merchants.blinkpay.co.nz/resources
BLINKPAY_CLIENT_ID=your_client_id
BLINKPAY_CLIENT_SECRET=your_client_secret
# Use sandbox (default: true). Set to "false" for production.
BLINKPAY_SANDBOX=true

# Optional: base URL for payment confirmation callback (where BlinkPay redirects after bank auth).
# Set this for local dev so the callback URL is explicit, e.g. http://localhost:5000
# APP_BASE_URL=http://localhost:5000

# Optional: use mock payment flow (no BlinkPay). Set to "true" to test without API credentials.
# USE_MOCK_PAYMENT=false
